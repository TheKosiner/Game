{
  "firestore": {
    "rules": "firestore.rules",
    "predeploy": [
      "npm run test:run"
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm run test:run",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ]
}
