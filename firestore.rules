rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── User profiles (private) ──────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Game saves (private) ─────────────────────────────────────────────────
    match /saves/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Public leaderboard profiles ──────────────────────────────────────────
    // Read: anyone authenticated (leaderboard)
    // Write: only the owner of that profile
    match /players/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ── Username uniqueness registry ─────────────────────────────────────────
    // Read: anyone authenticated (to check availability)
    // Write: only during own registration — the doc id IS the username,
    //        the value must contain the caller's uid
    match /usernames/{username} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
    }

    // ── Guilds ───────────────────────────────────────────────────────────────
    match /guilds/{guildId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated()
        && request.auth.uid in resource.data.members;
    }

    // ── Guild invites ─────────────────────────────────────────────────────────
    match /guildInvites/{inviteId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.toUid ||
        request.auth.uid == resource.data.fromUid
      );
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.toUid ||
        request.auth.uid == resource.data.fromUid
      );
    }

    // ── PvP fight history ─────────────────────────────────────────────────────
    // Read: any logged-in player
    // Create: only if the caller is the attacker in the record
    match /pvpHistory/{fightId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.attackerUid == request.auth.uid;
    }

    // ── Guild territories ─────────────────────────────────────────────────────
    // Read: any logged-in player
    // Write: only the guild leader of the current occupying guild OR
    //        if the territory is being claimed (no current occupier)
    match /territories/{territoryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        // Territory is unoccupied — anyone can start a siege
        !exists(/databases/$(database)/documents/territories/$(territoryId)) ||
        // Or the caller is the guild leader of the occupying guild
        resource.data.guildLeaderUid == request.auth.uid ||
        // Or the caller is the guild leader of the attacking guild in the new data
        request.resource.data.guildLeaderUid == request.auth.uid
      );
    }

    // ── In-game mail ──────────────────────────────────────────────────────────
    match /mail/{mailId} {
      allow read, delete: if isAuthenticated()
        && resource.data.toUid == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.fromUid == request.auth.uid;
    }

  }
}
