rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // User profiles (private)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Game saves (private)
    match /saves/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Public leaderboard profiles
    // Owner can write anything; any authenticated user may update only
    // guildId/guildTag (needed when guild leader disbands or kicks members)
    match /players/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['guildId', 'guildTag']);
    }

    // Username uniqueness registry
    // Doc id = lowercased username; must contain caller's uid on create
    match /usernames/{username} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
    }

    // Guilds
    match /guilds/{guildId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.members;
      // Territory siege: attacker sets lastLostAt on defending guild (not a member)
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLostAt']);
      allow delete: if isAuthenticated()
        && request.auth.uid in resource.data.members;
    }

    // Guild invites
    match /guildInvites/{inviteId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.toUid ||
        request.auth.uid == resource.data.fromUid
      );
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.toUid ||
        request.auth.uid == resource.data.fromUid
      );
    }

    // PvP fight history
    // Write requires caller to be the attacker (prevents forged fight records)
    match /pvpHistory/{fightId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.attackerUid == request.auth.uid;
    }

    // Guild territories
    // Any guild member can participate in a siege (damage, join, capture)
    // Client-side logic + validatePlayerUpdate Cloud Function guard abuse
    match /territories/{territoryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // In-game mail
    match /mail/{mailId} {
      allow read, delete: if isAuthenticated()
        && resource.data.toUid == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.fromUid == request.auth.uid;
    }

  }
}
