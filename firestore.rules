rules_version = '2';
// Last deployed: 2026-06-02 v8
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'thekosiner@gmail.com';
    }

    // ── Time-based validation using SERVER time (request.time) ────────────────

    function validQuestClear(old, nw) {
      return old.activeQuest == null
        || nw.activeQuest != null
        || request.time.toMillis() >= old.activeQuest.endsAt
        || old.activeQuest.endsAt > request.time.toMillis() + 3600000;
    }

    function validBeggingClear(old, nw) {
      return old.hero.beggingUntil == null
        || nw.hero.beggingUntil != null
        || nw.hero.beggingReward == null
        || request.time.toMillis() >= old.hero.beggingUntil
        || old.hero.beggingUntil > request.time.toMillis() + 172800000;
    }

    // Null-safe: treat missing lastDailyReset as 0 (very old saves lack this field).
    function validDailyReset(old, nw) {
      let oldReset = old.hero.lastDailyReset == null ? 0 : old.hero.lastDailyReset;
      return nw.hero.lastDailyReset == oldReset
        || oldReset > request.time.toMillis()
        || (nw.hero.lastDailyReset >= request.time.toMillis() - 300000
            && nw.hero.lastDailyReset <= request.time.toMillis() + 10000
            && request.time.toMillis() - oldReset >= 82800000);
    }

    function validRestClear(old, nw) {
      return old.hero.voluntaryRestUntil == null
        || nw.hero.voluntaryRestUntil != null
        || (nw.hero.voluntaryRestHp == null && nw.hero.voluntaryRestStartAt == null
            && request.time.toMillis() < old.hero.voluntaryRestUntil)
        || request.time.toMillis() >= old.hero.voluntaryRestUntil
        || old.hero.voluntaryRestUntil > request.time.toMillis() + 172800000;
    }

    // Null-safe: treat missing lastChallengeAt as 0.
    function validChallengeCooldown(old, nw) {
      let COOLDOWN_MS = 3600000;
      let oldAt = old.lastChallengeAt == null ? 0 : old.lastChallengeAt;
      return nw.lastChallengeAt <= oldAt
        || oldAt == 0
        || oldAt > request.time.toMillis()
        || request.time.toMillis() - oldAt >= COOLDOWN_MS;
    }

    // updatedAt is written as serverTimestamp() — Firestore sets it to request.time.
    // This check is exact and independent of the client's device clock.
    function validTimestamp(nw) {
      return nw.updatedAt == request.time;
    }

    // Gold earned today. Null-safe: missing goldEarnedToday treated as 0.
    function validGoldEarned(old, nw) {
      let oldEarned = old.hero.goldEarnedToday == null ? 0 : old.hero.goldEarnedToday;
      let dailyReset = nw.hero.lastDailyReset != old.hero.lastDailyReset;
      // After a daily reset the baseline is 0, not yesterday's total.
      let earnedDelta = nw.hero.goldEarnedToday - (dailyReset ? 0 : oldEarned);
      // Completed tasks started before today's reset are collected outside goldEarnedToday
      // (client adds gold directly without touching the cap).
      // beggingUntil elapsed check distinguishes full collect from early cancel.
      let beggingPending = (dailyReset
        && old.hero.beggingReward != null && nw.hero.beggingReward == null
        && old.hero.beggingStartAt != null && old.hero.beggingStartAt < nw.hero.lastDailyReset
        && old.hero.beggingUntil != null && old.hero.beggingUntil <= request.time.toMillis())
        ? old.hero.beggingReward : 0;
      let questPending = (dailyReset
        && old.activeQuest != null && nw.activeQuest == null
        && old.activeQuest.startedAt != null && old.activeQuest.startedAt < nw.hero.lastDailyReset
        && old.activeQuest.endsAt != null && old.activeQuest.endsAt <= request.time.toMillis()
        && old.activeQuest.quest != null)
        ? (old.activeQuest.quest.goldReward == null ? 0 : old.activeQuest.quest.goldReward) : 0;
      return
        (dailyReset
          ? nw.hero.goldEarnedToday >= 0
          : nw.hero.goldEarnedToday >= oldEarned)
        && nw.hero.goldEarnedToday <= 250000000
        && nw.hero.gold >= 0
        && nw.hero.gold <= 1000000000
        && nw.hero.gold <= old.hero.gold + earnedDelta + beggingPending + questPending;
    }

    // Null-safe: beggingReward must not exceed the daily gold cap when set.
    function validBeggingReward(nw) {
      return nw.hero.beggingReward == null
        || nw.hero.beggingReward <= 250000000;
    }

    // Gems are premium currency. Client writes may only ADD small amounts that come
    // from level-ups (+3/level, capped to +5 levels = +15 per save) and the daily
    // reward. All larger sources (Stripe purchases, daily reward) are credited
    // server-side by Cloud Functions before the client save lands, so by then the
    // baseline already includes them and the client delta stays ~0. Spending freely
    // decreases. This blocks "set gems to a million" localStorage tampering.
    function validGems(old, nw) {
      let oldGems = old.hero.gems == null ? 0 : old.hero.gems;
      return nw.hero.gems is number
        && nw.hero.gems >= 0
        && nw.hero.gems <= oldGems + 20;
    }

    // streakDays is written exclusively by the claimDailyReward Cloud Function
    // (admin SDK, bypasses rules). Clients must never increase it — doing so
    // would let a player fake a 19-day streak and claim a legendary chest.
    function validStreakDays(old, nw) {
      let oldStreak = old.hero.streakDays == null ? 0 : old.hero.streakDays;
      return nw.hero.streakDays == null || nw.hero.streakDays <= oldStreak;
    }

    // Daily run counters must only go up during a session.
    // The CF resets them to 0 via admin SDK at the start of each day;
    // until then a client must not decrease them (bypass daily limit exploit).
    function validDailyCounters(old, nw) {
      let oldDng = old.hero.dungeonRunsToday     == null ? 0 : old.hero.dungeonRunsToday;
      let oldKry = old.hero.kryptaRunsToday      == null ? 0 : old.hero.kryptaRunsToday;
      let oldQst = old.hero.questsCompletedToday == null ? 0 : old.hero.questsCompletedToday;
      return nw.hero.dungeonRunsToday     >= oldDng
          && nw.hero.kryptaRunsToday      >= oldKry
          && nw.hero.questsCompletedToday >= oldQst;
    }

    // ── Stat delta validation — blocks localStorage inflation ─────────────────
    function validSaveUpdate(old, nw) {
      return
        nw.hero.level <= old.hero.level + 5
        && nw.pvpWins   >= old.pvpWins
        && nw.pvpWins   <= old.pvpWins + 1
        && nw.pvpLosses >= old.pvpLosses
        && nw.pvpLosses <= old.pvpLosses + 1
        && nw.pvpRating <= old.pvpRating + 30
        && nw.pvpRating >= old.pvpRating - 20
        && nw.challengeUnlocked >= old.challengeUnlocked
        && nw.challengeUnlocked <= old.challengeUnlocked + 1
        && validGoldEarned(old, nw)
        && validQuestClear(old, nw)
        && validBeggingClear(old, nw)
        && validDailyReset(old, nw)
        && validRestClear(old, nw)
        && validChallengeCooldown(old, nw)
        && validBeggingReward(nw)
        && validGems(old, nw)
        && validStreakDays(old, nw)
        && validDailyCounters(old, nw)
        && validTimestamp(nw);
    }

    function validPlayerUpdate(old, nw) {
      // PvP stat constraints live in validSaveUpdate (saves collection).
      // Only guard against large level jumps on the public profile.
      return nw.level <= old.level + 20;
    }

    // User profiles (private)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Game saves — delta + time validation on every write
    match /saves/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAdmin()
        || (isOwner(userId) && validSaveUpdate(resource.data, request.resource.data));
    }

    // Public leaderboard profiles
    match /players/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isAdmin();
      allow update: if isOwner(userId) && validPlayerUpdate(resource.data, request.resource.data);
      // Only the document owner may update their own guild membership fields
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['guildId', 'guildTag']);
    }

    // Username uniqueness registry
    match /usernames/{username} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
    }

    // Guilds
    match /guilds/{guildId} {
      allow read: if isAuthenticated();
      // Creator must set themselves as leader
      allow create: if isAuthenticated()
        && request.resource.data.leaderUid == request.auth.uid;
      // Guild leader can update anything
      allow update: if isAuthenticated()
        && resource.data.leaderUid == request.auth.uid;
      // Officers can update anything except leaderUid (prevents self-promotion to leader)
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.members
        && resource.data.members[request.auth.uid].role == 'officer'
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['leaderUid']);
      // Regular members may only deposit to treasury
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.members
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['treasury', 'contributions'])
        && request.resource.data.treasury >= resource.data.treasury;
      // Regular members may update operation progress but cannot increase pendingReward amounts
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.members
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guildOperation'])
        && (resource.data.guildOperation == null
            || request.resource.data.guildOperation == null
            || resource.data.guildOperation.pendingReward == null
            || request.resource.data.guildOperation.pendingReward == null
            || (request.resource.data.guildOperation.pendingReward.gold <= resource.data.guildOperation.pendingReward.gold
                && request.resource.data.guildOperation.pendingReward.xp <= resource.data.guildOperation.pendingReward.xp));
      // Joining via invite: non-member adds only themselves as role='member'
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
        && !(request.auth.uid in resource.data.members)
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members[request.auth.uid].role == 'member';
      allow delete: if isAuthenticated()
        && resource.data.leaderUid == request.auth.uid;
    }

    // Guild invites
    match /guildInvites/{inviteId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.toUid ||
        request.auth.uid == resource.data.fromUid
      );
      // Sender must be the authenticated user
      allow create: if isAuthenticated()
        && request.resource.data.fromUid == request.auth.uid;
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.toUid ||
        request.auth.uid == resource.data.fromUid
      );
    }

    // PvP fight history
    match /pvpHistory/{fightId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.attackerUid == request.auth.uid;
    }

    // Guild Wars — all writes via Cloud Functions (admin SDK); clients read-only
    match /guildWars/{warId} {
      allow read: if isAuthenticated();
    }

    // In-game mail
    match /mail/{mailId} {
      allow read, delete: if isAuthenticated()
        && resource.data.toUid == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.toUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAuthenticated()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.body.size() <= 2000;
    }

    // Stripe gem credits — written only by Cloud Functions (admin SDK bypasses rules)
    match /gemCredits/{creditId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Lobby presence (one doc per player, owner-only write)
    match /lobbyPlayers/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Lobby chat
    match /lobbyChat/{msgId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text.size() <= 200;
    }

    // Global chat
    match /globalChat/{msgId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text.size() <= 200;
    }

    // Casino spin history (global feed)
    match /casinoSpins/{spinId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.stake >= 1
        && request.resource.data.stake <= 10000000;
    }

    // Guild chat
    match /guilds/{guildId}/messages/{msgId} {
      allow read: if isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/guilds/$(guildId)).data.members;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.auth.uid in get(/databases/$(database)/documents/guilds/$(guildId)).data.members
        && request.resource.data.text.size() <= 200;
    }

    // Client-side error logs — any authenticated user can write, only admin can read/delete
    match /clientErrors/{errorId} {
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 500;
      allow read, delete: if isAdmin();
    }

    // Guild boss
    match /guilds/{guildId}/boss/{doc} {
      allow read: if isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/guilds/$(guildId)).data.members;
      allow write: if isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/guilds/$(guildId)).data.members;
    }

  }
}
