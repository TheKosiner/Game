rules_version = '2';
// Last deployed: 2026-05-26 v5
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'thekosiner@gmail.com';
    }

    // ── Time-based validation using SERVER time (request.time) ────────────────
    // These replace Cloud Functions for timer validation — work on Spark plan

    // Quest collection: if activeQuest is cleared, server time must be past endsAt.
    // If endsAt is >1 h in the future, the value is corrupted — allow correction.
    // (skips check if quest is being abandoned mid-run — same null result but
    //  questsCompletedToday won't increment on abandon, so reward can't be gamed)
    function validQuestClear(old, nw) {
      return old.activeQuest == null
        || nw.activeQuest != null
        || request.time.toMillis() >= old.activeQuest.endsAt
        || old.activeQuest.endsAt > request.time.toMillis() + 3600000;
    }

    // Begging: if beggingUntil cleared AND beggingReward consumed, time must be past.
    // If beggingUntil is >48 h in the future, the value is corrupted — allow correction.
    function validBeggingClear(old, nw) {
      return old.hero.beggingUntil == null
        || nw.hero.beggingUntil != null
        // cancelled early (reward nulled too — no gold awarded at full rate)
        || nw.hero.beggingReward == null
        // completed: server time past end
        || request.time.toMillis() >= old.hero.beggingUntil
        || old.hero.beggingUntil > request.time.toMillis() + 172800000;
    }

    // lastDailyReset: if changed, new value must be ≈ server time AND at least 23 h must have
    // elapsed since the previous reset (blocks spamming daily resets for repeated gold injection).
    // If old value is in the future (corrupted clock), allow correction without the cooldown.
    function validDailyReset(old, nw) {
      return nw.hero.lastDailyReset == old.hero.lastDailyReset
        || old.hero.lastDailyReset > request.time.toMillis()
        || (nw.hero.lastDailyReset >= request.time.toMillis() - 300000
            && nw.hero.lastDailyReset <= request.time.toMillis() + 10000
            && request.time.toMillis() - old.hero.lastDailyReset >= 82800000);
    }

    // Voluntary rest: voluntaryRestUntil can only be cleared after server time passes it.
    // If voluntaryRestUntil is >48 h in the future, the value is corrupted — allow correction.
    function validRestClear(old, nw) {
      return old.hero.voluntaryRestUntil == null
        || nw.hero.voluntaryRestUntil != null
        // cancelled early — no full reward (voluntaryRestHp must decrease or stay null)
        || (nw.hero.voluntaryRestHp == null && nw.hero.voluntaryRestStartAt == null
            && request.time.toMillis() < old.hero.voluntaryRestUntil)
        // completed: server time must be past the rest end
        || request.time.toMillis() >= old.hero.voluntaryRestUntil
        || old.hero.voluntaryRestUntil > request.time.toMillis() + 172800000;
    }

    // Challenge cooldown: lastChallengeAt can only increase after 1 h from server's view.
    // If old value is in the future (corrupted clock), allow correction to any value.
    function validChallengeCooldown(old, nw) {
      let COOLDOWN_MS = 3600000; // 1 hour
      return nw.lastChallengeAt <= old.lastChallengeAt
        || old.lastChallengeAt == 0
        || old.lastChallengeAt > request.time.toMillis()
        || request.time.toMillis() - old.lastChallengeAt >= COOLDOWN_MS;
    }

    // updatedAt must be ≈ server time — blocks writes where clock was advanced >60 s
    function validTimestamp(nw) {
      return nw.updatedAt <= request.time.toMillis() + 60000
        && nw.updatedAt >= request.time.toMillis() - 300000;
    }

    // Casino spin: lastCasinoSpinAt can only increase, and if it changed it must
    // match server time (blocks backdating wins and bulk-simulating offline spins).
    // Same pattern as validDailyReset / validTimestamp for quest timers.
    function validCasinoSpin(old, nw) {
      return nw.hero.lastCasinoSpinAt >= old.hero.lastCasinoSpinAt
        && (nw.hero.lastCasinoSpinAt == old.hero.lastCasinoSpinAt
            || (nw.hero.lastCasinoSpinAt <= request.time.toMillis() + 10000
                && nw.hero.lastCasinoSpinAt >= request.time.toMillis() - 300000));
    }

    // Gold earned today: shared counter for ALL gold sources (dungeons, quests, casino, etc.).
    // - Only increases within a day; resets to 0 with lastDailyReset.
    // - Capped at 250 M / day — covers max legitimate dungeon+begging+casino play.
    // - KEY: gold can only increase this write by as much as goldEarnedToday increased.
    //   This makes gold gains auditable: every increase must be declared in earnedToday.
    function validGoldEarned(old, nw) {
      let dailyReset = nw.hero.lastDailyReset != old.hero.lastDailyReset;
      // On daily reset: earnedDelta = 0. The reset itself grants no gold — it just zeroes the
      // counter. Gold can only stay the same or decrease on the write that triggers the reset.
      // BUG FIX: previously used nw.goldEarnedToday as earnedDelta on reset, allowing a client to
      // inject up to 250 M gold by setting goldEarnedToday=250M in the same write as lastDailyReset.
      let earnedDelta = dailyReset
        ? 0
        : nw.hero.goldEarnedToday - old.hero.goldEarnedToday;
      return
        (dailyReset
          ? nw.hero.goldEarnedToday >= 0
          : nw.hero.goldEarnedToday >= old.hero.goldEarnedToday)
        && nw.hero.goldEarnedToday <= 250000000
        && nw.hero.gold >= 0
        && nw.hero.gold <= 1000000000
        && nw.hero.gold <= old.hero.gold + earnedDelta;
    }

    // ── Stat delta validation — blocks localStorage inflation ─────────────────
    function validSaveUpdate(old, nw) {
      return
        // Level: max +5 per write
        nw.hero.level <= old.hero.level + 5
        // PvP wins/losses: only increase, max +1 per write
        && nw.pvpWins   >= old.pvpWins
        && nw.pvpWins   <= old.pvpWins + 1
        && nw.pvpLosses >= old.pvpLosses
        && nw.pvpLosses <= old.pvpLosses + 1
        // PvP rating: bounded change (+25 win / -15 loss, with margin)
        && nw.pvpRating <= old.pvpRating + 30
        && nw.pvpRating >= old.pvpRating - 20
        // Challenge unlock: only increases, max +1 per write
        && nw.challengeUnlocked >= old.challengeUnlocked
        && nw.challengeUnlocked <= old.challengeUnlocked + 1
        // Gold: validated via goldEarnedToday counter (see validGoldEarned above)
        && validGoldEarned(old, nw)
        // Time-based: server validates all timers (blocks clock-manipulation cheats)
        && validQuestClear(old, nw)
        && validBeggingClear(old, nw)
        && validDailyReset(old, nw)
        && validRestClear(old, nw)
        && validChallengeCooldown(old, nw)
        && validCasinoSpin(old, nw)
        && validTimestamp(nw);
    }

    function validPlayerUpdate(old, nw) {
      return
        nw.level      <= old.level + 5
        && nw.pvpWins   >= old.pvpWins
        && nw.pvpWins   <= old.pvpWins + 1
        && nw.pvpLosses >= old.pvpLosses
        && nw.pvpLosses <= old.pvpLosses + 1
        && nw.pvpRating <= old.pvpRating + 30
        && nw.pvpRating >= old.pvpRating - 20;
    }

    // User profiles (private)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Game saves — delta + time validation on every write
    match /saves/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAdmin()
        || (isOwner(userId) && validSaveUpdate(resource.data, request.resource.data));
    }

    // Public leaderboard profiles
    match /players/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && validPlayerUpdate(resource.data, request.resource.data);
      // Only the document owner may update their own guild membership fields
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['guildId', 'guildTag']);
    }

    // Username uniqueness registry
    match /usernames/{username} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
    }

    // Guilds
    match /guilds/{guildId} {
      allow read: if isAuthenticated();
      // Creator must set themselves as leader
      allow create: if isAuthenticated()
        && request.resource.data.leaderUid == request.auth.uid;
      // Guild leader can update anything
      allow update: if isAuthenticated()
        && resource.data.leaderUid == request.auth.uid;
      // Officers can update anything except leaderUid (prevents self-promotion to leader)
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.members
        && resource.data.members[request.auth.uid].role == 'officer'
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['leaderUid']);
      // Regular members may only touch treasury (deposit only), contributions, and operation state
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.members
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['treasury', 'contributions', 'guildOperation', 'lastLostAt'])
        && request.resource.data.treasury >= resource.data.treasury;
      // Joining via invite: non-member adds only themselves as role='member'
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
        && !(request.auth.uid in resource.data.members)
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members[request.auth.uid].role == 'member';
      allow delete: if isAuthenticated()
        && request.auth.uid in resource.data.members;
    }

    // Guild invites
    match /guildInvites/{inviteId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.toUid ||
        request.auth.uid == resource.data.fromUid
      );
      // Sender must be the authenticated user
      allow create: if isAuthenticated()
        && request.resource.data.fromUid == request.auth.uid;
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.toUid ||
        request.auth.uid == resource.data.fromUid
      );
    }

    // PvP fight history
    match /pvpHistory/{fightId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.attackerUid == request.auth.uid;
    }

    // Guild territories — write requires membership in the guild claiming/updating the territory
    match /territories/{territoryId} {
      allow read: if isAuthenticated();
      // Allow write only if the caller is a member of the guild referenced in the document.
      // Covers both creating a new claim and updating/sieging an existing territory.
      allow write: if isAuthenticated()
        && (
          // New territory claim: caller must be in the guild they are claiming for
          (resource == null
            && request.resource.data.guildId != null
            && request.auth.uid in get(/databases/$(database)/documents/guilds/$(request.resource.data.guildId)).data.members)
          // Update / siege: caller must be in the defending guild OR the attacking guild
          || (resource != null
              && resource.data.guildId != null
              && request.auth.uid in get(/databases/$(database)/documents/guilds/$(resource.data.guildId)).data.members)
          || (resource != null
              && request.resource.data.siegeGuildId != null
              && request.auth.uid in get(/databases/$(database)/documents/guilds/$(request.resource.data.siegeGuildId)).data.members)
        );
    }

    // In-game mail
    match /mail/{mailId} {
      allow read, delete: if isAuthenticated()
        && resource.data.toUid == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.toUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAuthenticated()
        && request.resource.data.fromUid == request.auth.uid;
    }

    // Stripe gem credits — written only by Cloud Functions (admin SDK bypasses rules)
    match /gemCredits/{creditId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Global chat
    match /globalChat/{msgId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text.size() <= 200;
    }

    // Guild chat
    match /guilds/{guildId}/messages/{msgId} {
      allow read: if isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/guilds/$(guildId)).data.members;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.auth.uid in get(/databases/$(database)/documents/guilds/$(guildId)).data.members
        && request.resource.data.text.size() <= 200;
    }

    // Guild boss
    match /guilds/{guildId}/boss/{doc} {
      allow read: if isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/guilds/$(guildId)).data.members;
      allow write: if isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/guilds/$(guildId)).data.members;
    }

  }
}
