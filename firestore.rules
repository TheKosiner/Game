rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidHeroLevel(level) {
      return level is int && level >= 1 && level <= 100;
    }

    function isValidGold(gold) {
      return gold is int && gold >= 0 && gold <= 1000000;
    }

    function isValidXp(xp) {
      return xp is int && xp >= 0;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /players/{uid} {
      allow read: if isAuthenticated();

      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(['username', 'heroName', 'heroClass', 'level', 'xp', 'gold'])
        && isValidHeroLevel(request.resource.data.level)
        && isValidGold(request.resource.data.gold)
        && isValidXp(request.resource.data.xp);

      allow update: if isOwner(uid)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['level', 'gold', 'xp'])
          || (
            isValidHeroLevel(request.resource.data.level)
            && isValidGold(request.resource.data.gold)
            && isValidXp(request.resource.data.xp)
            && request.resource.data.level <= resource.data.level + 5
            && request.resource.data.gold <= resource.data.gold + 10000
          )
        );

      allow delete: if isOwner(uid);
    }

    match /guilds/{guildId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.leaderId == request.auth.uid
        && request.resource.data.keys().hasAll(['name', 'tag', 'leaderId', 'createdAt', 'members']);

      allow update: if isAuthenticated()
        && (
          resource.data.leaderId == request.auth.uid
          || resource.data.members[request.auth.uid].role in ['leader', 'officer']
        );

      allow delete: if isAuthenticated()
        && resource.data.leaderId == request.auth.uid;
    }

    match /territories/{territoryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /pvp_results/{resultId} {
      allow read: if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
